{
    "metadata": {
        "scenario_id": "emergency-command",
        "version": "3.1.0"
    },
    "id": "emergency-command",
    "name": "应急指挥场景",
    "keywords": [
        "应急指挥",
        "事件响应",
        "资源调度",
        "协同处置",
        "态势感知",
        "决策支持"
    ],
    "synonyms": [
        "应急处置",
        "突发事件",
        "应急响应",
        "应急管理",
        "指挥调度",
        "联合指挥"
    ],
    "priority": 10,
    "goal": "展示事件点、影响范围、调度资源、联动窗口与视角。",
    "task_breakdown": [
        "创建事件点位和影响范围",
        "创建调度资源对象",
        "创建路径并驱动资源运动",
        "注册事件联动和状态更新",
        "补充窗口、资源、事件监听的清理链路"
    ],
    "primary_skills": [
        "reference/scene/covering/poi/SKILL.md"
    ],
    "secondary_skills": [
        "reference/scene/covering/bound/SKILL.md",
        "reference/camera/camera-control/SKILL.md",
        "reference/renderer/SKILL.md"
    ],
    "required_clarifications": [
        "事件点和影响范围的数据来源",
        "调度资源的对象类别和对象 Id 来源",
        "是否需要实时状态更新",
        "离开页面时哪些对象必须清空"
    ],
    "modules": [
        {
            "name": "事件标注模块",
            "wdp_apis": [
                "new App.Poi({...})",
                "poiStyle.markerNormalUrl",
                "poiStyle.labelContent"
            ]
        },
        {
            "name": "资源粒子模块",
            "wdp_apis": [
                "new App.Particle({...})",
                "particleType",
                "particleStyle.scale3d",
                "particleStyle.url"
            ]
        },
        {
            "name": "调度路径模块",
            "wdp_apis": [
                "new App.Path({...})",
                "pathStyle.type",
                "pathStyle.lineColor",
                "pathStyle.lineWidth"
            ]
        },
        {
            "name": "资源移动模块",
            "wdp_apis": [
                "new App.Bound({...})",
                "boundStyle.time",
                "boundStyle.bLoop",
                "boundStyle.speed"
            ]
        },
        {
            "name": "态势范围模块",
            "wdp_apis": [
                "new App.Range({...})",
                "rangeStyle.fillColor",
                "rangeStyle.outlineColor",
                "rangeStyle.height"
            ]
        },
        {
            "name": "信息窗口模块",
            "wdp_apis": [
                "new App.Window({...})",
                "windowStyle.url",
                "windowStyle.size"
            ]
        },
        {
            "name": "场景管理模块",
            "wdp_apis": [
                "App.Scene.Add",
                "App.Scene.Update",
                "App.Scene.Delete"
            ]
        },
        {
            "name": "相机控制模块",
            "wdp_apis": [
                "App.CameraControl.SetCameraPose",
                "App.CameraControl.FlyTo"
            ]
        }
    ],
    "api_flow": [
        {
            "step": 1,
            "description": "创建应急事件POI标注",
            "api": "new App.Poi({...}) + App.Scene.Add(entity)",
            "params": {
                "entity": "new App.Poi({...})",
                "config": {
                    "location": "[116.4074, 39.9042, 50]",
                    "poiStyle": {
                        "markerNormalUrl": "fire_emergency_icon.png",
                        "labelContent": ["火灾事件", "#FFFFFFFF", 14]
                    },
                    "customId": "emergency_event_1"
                }
            }
        },
        {
            "step": 2,
            "description": "创建危险范围区域",
            "api": "new App.Range({...}) + App.Scene.Add(entity)",
            "params": {
                "entity": "new App.Range({...})",
                "config": {
                    "polygon": {
                        "coordinates": "[[116.407, 39.904], [116.408, 39.904], ...]"
                    },
                    "rangeStyle": {
                        "fillColor": "rgba(255, 0, 0, 0.2)",
                        "outlineColor": "#ff0000",
                        "height": 100
                    },
                    "customId": "danger_zone_1"
                }
            }
        },
        {
            "step": 3,
            "description": "创建应急资源粒子实体",
            "api": "new App.Particle({...}) + App.Scene.Add(entity)",
            "params": {
                "entity": "new App.Particle({...})",
                "config": {
                    "location": "[116.400, 39.900, 0]",
                    "particleType": "vehicle_fire_truck",
                    "particleStyle": {
                        "scale3d": [1.2, 1.2, 1.2]
                    },
                    "customId": "fire_truck_1"
                }
            }
        },
        {
            "step": 4,
            "description": "规划资源调度路径",
            "api": "new App.Path({...}) + App.Scene.Add(entity)",
            "params": {
                "entity": "new App.Path({...})",
                "config": {
                    "polyline": {
                        "coordinates": "[[116.400, 39.900, 0], [116.4074, 39.9042, 0]]"
                    },
                    "pathStyle": {
                        "type": "arrow",
                        "lineColor": "#ff6600",
                        "lineWidth": 4
                    },
                    "customId": "dispatch_path_1"
                }
            }
        },
        {
            "step": 5,
            "description": "绑定资源到调度路径",
            "api": "new App.Bound({...}) + App.Scene.Add(entity)",
            "params": {
                "entity": "new App.Bound({...})",
                "config": {
                    "moving": "${fireTruckParticle}",
                    "path": "${dispatchPath}",
                    "boundStyle": {
                        "time": 60,
                        "bLoop": false,
                        "speed": 1.5
                    },
                    "customId": "resource_bound_1"
                }
            }
        },
        {
            "step": 6,
            "description": "聚焦到应急事件位置",
            "api": "App.CameraControl.SetCameraPose",
            "params": {
                "target": "[116.4074, 39.9042, 50]",
                "pitch": -60,
                "yaw": 0,
                "distance": 500
            }
        },
        {
            "step": 7,
            "description": "创建态势信息窗口",
            "api": "new App.Window({...}) + App.Scene.Add(entity)",
            "params": {
                "entity": "new App.Window({...})",
                "config": {
                    "location": "[116.4074, 39.9042, 50]",
                    "windowStyle": {
                        "url": "emergency_dashboard.html?eventId=event_1",
                        "size": [400, 500],
                        "offset": [0, 2]
                    },
                    "customId": "situation_window_1"
                }
            }
        },
        {
            "step": 8,
            "description": "注册资源到达事件",
            "api": "App.Renderer.RegisterSceneEvent('OnMoveAlongPathEndEvent', func)",
            "params": {
                "name": "OnMoveAlongPathEndEvent",
                "func": "async (ev) => { if(ev.result.customId.startsWith('resource_bound')) { /* 资源到达，更新状态 */ } }"
            }
        },
        {
            "step": 9,
            "description": "更新事件状态标注",
            "api": "entity.Update({...})",
            "params": {
                "entity": "poiObj",
                "updateData": {
                    "poiStyle": {
                        "markerNormalUrl": "fire_controlled_icon.png",
                        "labelContent": ["火灾事件 (处置中)", "#FFFFFFFF", 14]
                    }
                }
            }
        }
    ],
    "data_flow": [
        {
            "step": "new App.Poi({...}) / new App.Range({...}) + App.Scene.Add(entity)",
            "output": "result.object（含 eid, customId, location）",
            "usage": "缓存用于清理和后续更新"
        },
        {
            "step": "OnMoveAlongPathEndEvent 回调",
            "output": "result.customId",
            "usage": "用于判断资源到达，触发状态更新"
        }
    ],
    "cleanup_chain": [
        {
            "create": "new App.Poi({...}) + App.Scene.Add(entity)",
            "cleanup": "poiObj.Delete()"
        },
        {
            "create": "new App.Range({...}) + App.Scene.Add(entity)",
            "cleanup": "rangeObj.Delete()"
        },
        {
            "create": "new App.Particle({...}) + App.Scene.Add(entity)",
            "cleanup": "particleObj.Delete()"
        },
        {
            "create": "new App.Path({...}) + App.Scene.Add(entity)",
            "cleanup": "pathObj.Delete()"
        },
        {
            "create": "new App.Bound({...}) + App.Scene.Add(entity)",
            "cleanup": "boundObj.Delete()"
        },
        {
            "create": "new App.Window({...}) + App.Scene.Add(entity)",
            "cleanup": "windowObj.Delete()"
        },
        {
            "create": "RegisterSceneEvent",
            "cleanup": "UnRegisterSceneEvent"
        }
    ],
    "pattern": {
        "type": "command-control",
        "architecture": "real-time-3d-visualization",
        "data_flow": "event-driven-spatial",
        "recommended_patterns": [
            "wdp-path-roam-animation",
            "wdp-poi-window-interaction"
        ],
        "key_features": [
            "3D态势可视化",
            "实时资源调度",
            "路径动画展示",
            "事件状态追踪",
            "空间范围标注",
            "相机智能聚焦"
        ]
    }
}