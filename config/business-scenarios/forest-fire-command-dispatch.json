{
  "metadata": {
    "scenario_id": "forest-fire-command-dispatch",
    "version": "3.1.0"
  },
  "id": "forest-fire-command-dispatch",
  "name": "森林防火扑救指挥场景",
  "keywords": [
    "森林防火",
    "扑救指挥",
    "林火",
    "火点",
    "扑火队伍",
    "灭火路径"
  ],
  "synonyms": [
    "森林消防",
    "山火扑救",
    "林火指挥",
    "灭火调度",
    "防火指挥"
  ],
  "priority": 10,
  "goal": "围绕火点、危险范围、扑救队伍和行动路径做联动展示。",
  "task_breakdown": [
    "创建火点和危险范围对象",
    "创建队伍或车辆对象",
    "创建行动路径并驱动运动",
    "按点击或事件联动聚焦和窗口",
    "补充停止、回退和清理链路"
  ],
  "primary_skills": [
    "reference/scene/covering/poi/SKILL.md",
    "reference/scene/covering/bound/SKILL.md"
  ],
  "secondary_skills": [
    "reference/camera/camera-control/SKILL.md",
    "reference/renderer/SKILL.md"
  ],
  "required_clarifications": [
    "火点、范围和队伍各自的数据来源",
    "是否需要多队伍并发运动",
    "是否需要时间推进或回放",
    "联动窗口和事件监听的清理方式"
  ],
  "modules": [
    {
      "name": "火点特效模块",
      "wdp_apis": [
        "new App.Particle({...})",
        "App.Scene.Add",
        "App.Scene.Update"
      ],
      "purpose": "创建火点特效并支持点击/自动触发"
    },
    {
      "name": "危险范围模块",
      "wdp_apis": [
        "new App.Range({...})",
        "App.Scene.Add",
        "App.Scene.Update"
      ],
      "purpose": "展示火场态势范围与风险圈层"
    },
    {
      "name": "队伍POI模块",
      "wdp_apis": [
        "new App.Poi({...})",
        "App.Scene.Add",
        "App.Scene.Update"
      ],
      "purpose": "按小组与车辆装备展示扑救队伍位置"
    },
    {
      "name": "行动路径模块",
      "wdp_apis": [
        "new App.Path({...})",
        "App.Scene.Add",
        "App.Scene.Update"
      ],
      "purpose": "标记各扑救小组行动路径"
    },
    {
      "name": "路径回放与移动模块",
      "wdp_apis": [
        "new App.Bound({...})",
        "App.Scene.Add",
        "App.Scene.Update"
      ],
      "purpose": "队伍沿路径移动并支持时间推进回放"
    },
    {
      "name": "镜头聚焦模块",
      "wdp_apis": [
        "App.CameraControl.SetCameraPose",
        "App.CameraControl.FlyTo"
      ],
      "purpose": "点击或异常时聚焦火点/队伍"
    },
    {
      "name": "事件联动模块",
      "wdp_apis": [
        "App.Renderer.RegisterSceneEvent",
        "OnWdpSceneIsReady",
        "OnEntityClicked"
      ],
      "purpose": "场景就绪门禁、点击触发与自动告警触发联动"
    }
  ],
  "api_flow": [
    {
      "step": 1,
      "description": "创建火点POI标注",
      "api": "new App.Poi({...}) + App.Scene.Add(entity)",
      "params": {
        "entity": "new App.Poi({...})",
        "config": {
          "location": "[116.4074, 39.9042, 50]",
          "poiStyle": {
            "markerNormalUrl": "fire_icon.png",
            "labelContent": ["火点", "#FFFFFFFF", 14]
          },
          "customId": "fire_point_1"
        }
      }
    },
    {
      "step": 2,
      "description": "创建危险范围区域",
      "api": "new App.Range({...}) + App.Scene.Add(entity)",
      "params": {
        "entity": "new App.Range({...})",
        "config": {
          "polygon": {
            "coordinates": "[[116.407, 39.904], [116.408, 39.904], ...]"
          },
          "rangeStyle": {
            "fillColor": "rgba(255, 0, 0, 0.2)",
            "outlineColor": "#ff0000",
            "height": 100
          },
          "customId": "danger_zone_1"
        }
      }
    },
    {
      "step": 3,
      "description": "创建扑火队伍粒子实体",
      "api": "new App.Particle({...}) + App.Scene.Add(entity)",
      "params": {
        "entity": "new App.Particle({...})",
        "config": {
          "location": "[116.400, 39.900, 0]",
          "particleType": "vehicle_fire_truck",
          "particleStyle": {
            "scale3d": [1.2, 1.2, 1.2]
          },
          "customId": "fire_team_1"
        }
      }
    },
    {
      "step": 4,
      "description": "创建灭火行动路径",
      "api": "new App.Path({...}) + App.Scene.Add(entity)",
      "params": {
        "entity": "new App.Path({...})",
        "config": {
          "polyline": {
            "coordinates": "[[116.400, 39.900, 0], [116.4074, 39.9042, 0]]"
          },
          "pathStyle": {
            "type": "arrow",
            "lineColor": "#ff6600",
            "lineWidth": 4
          },
          "customId": "action_path_1"
        }
      }
    },
    {
      "step": 5,
      "description": "绑定队伍到行动路径",
      "api": "new App.Bound({...}) + App.Scene.Add(entity)",
      "params": {
        "entity": "new App.Bound({...})",
        "config": {
          "moving": "${fireTeamParticle}",
          "path": "${actionPath}",
          "boundStyle": {
            "time": 60,
            "bLoop": false,
            "speed": 1.5
          },
          "customId": "team_bound_1"
        }
      }
    },
    {
      "step": 6,
      "description": "聚焦到火点位置",
      "api": "App.CameraControl.SetCameraPose",
      "params": {
        "target": "[116.4074, 39.9042, 50]",
        "pitch": -60,
        "yaw": 0,
        "distance": 500
      }
    },
    {
      "step": 7,
      "description": "创建指挥信息窗口",
      "api": "new App.Window({...}) + App.Scene.Add(entity)",
      "params": {
        "entity": "new App.Window({...})",
        "config": {
          "location": "[116.4074, 39.9042, 50]",
          "windowStyle": {
            "url": "command_dashboard.html?fireId=fire_1",
            "size": [400, 500],
            "offset": [0, 2]
          },
          "customId": "command_window_1"
        }
      }
    },
    {
      "step": 8,
      "description": "注册队伍到达事件",
      "api": "App.Renderer.RegisterSceneEvent('OnMoveAlongPathEndEvent', func)",
      "params": {
        "name": "OnMoveAlongPathEndEvent",
        "func": "async (ev) => { if(ev.result.customId.startsWith('team_bound')) { /* 队伍到达，更新状态 */ } }"
      }
    },
    {
      "step": 9,
      "description": "更新火点状态标注",
      "api": "entity.Update({...})",
      "params": {
        "entity": "poiObj",
        "updateData": {
          "poiStyle": {
            "markerNormalUrl": "fire_controlled_icon.png",
            "labelContent": ["火点 (扑救中)", "#FFFFFFFF", 14]
          }
        }
      }
    }
  ],
  "data_flow": [
    {
      "step": "new App.Poi({...}) / new App.Range({...}) + App.Scene.Add(entity)",
      "output": "result.object（含 eid, customId, location）",
      "usage": "缓存用于清理和后续更新"
    },
    {
      "step": "OnMoveAlongPathEndEvent 回调",
      "output": "result.customId",
      "usage": "用于判断队伍到达，触发状态更新"
    }
  ],
  "cleanup_chain": [
    {"create": "new App.Poi({...}) + App.Scene.Add(entity)", "cleanup": "poiObj.Delete()"},
    {"create": "new App.Range({...}) + App.Scene.Add(entity)", "cleanup": "rangeObj.Delete()"},
    {"create": "new App.Particle({...}) + App.Scene.Add(entity)", "cleanup": "particleObj.Delete()"},
    {"create": "new App.Path({...}) + App.Scene.Add(entity)", "cleanup": "pathObj.Delete()"},
    {"create": "new App.Bound({...}) + App.Scene.Add(entity)", "cleanup": "boundObj.Delete()"},
    {"create": "new App.Window({...}) + App.Scene.Add(entity)", "cleanup": "windowObj.Delete()"},
    {"create": "RegisterSceneEvent", "cleanup": "UnRegisterSceneEvent"}
  ],
  "pattern": {
    "type": "command-control",
    "architecture": "real-time-3d-visualization",
    "data_flow": "event-driven-spatial",
    "recommended_patterns": ["wdp-path-roam-animation", "wdp-poi-window-interaction"],
    "key_features": [
      "3D态势可视化",
      "实时资源调度",
      "路径动画展示",
      "事件状态追踪",
      "空间范围标注",
      "相机智能聚焦"
    ]
  }
}