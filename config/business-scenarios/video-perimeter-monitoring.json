{
    "metadata": {
        "scenario_id": "video-perimeter-monitoring",
        "version": "3.1.0"
    },
    "id": "video-perimeter-monitoring",
    "name": "视频周界场景",
    "keywords": [
        "视频监控",
        "周界防护",
        "入侵检测",
        "实时告警",
        "视频分析",
        "AI识别"
    ],
    "synonyms": [
        "电子围栏",
        "围栏告警",
        "周界报警",
        "安防监控",
        "摄像头",
        "监控摄像",
        "视频点位",
        "安保监控",
        "视频联动",
        "围界"
    ],
    "priority": 10,
    "goal": "在三维场景中展示周界、监控点位、告警联动和视频窗口。",
    "task_breakdown": [
        "创建或加载周界范围对象",
        "创建监控点位或摄像头对象",
        "注册点击或告警联动事件",
        "触发视频窗口、聚焦或高亮",
        "补充离开页面后的清理链路"
    ],
    "primary_skills": [
        "reference/scene/covering/poi/SKILL.md",
        "reference/renderer/SKILL.md"
    ],
    "secondary_skills": [
        "reference/camera/camera-control/SKILL.md",
        "reference/tools/picker/SKILL.md"
    ],
    "required_clarifications": [
        "摄像头对象类别和对象 Id 来源",
        "周界范围坐标或数据来源",
        "点击联动还是自动告警联动",
        "视频窗口的关闭和清理方式"
    ],
    "modules": [
        {
            "name": "场景实体模块",
            "wdp_apis": [
                "App.Scene.Add",
                "App.Scene.Update",
                "App.Scene.Delete"
            ]
        },
        {
            "name": "POI标注模块",
            "wdp_apis": [
                "new App.Poi({...})",
                "poiStyle.markerNormalUrl",
                "poiStyle.markerActivateUrl",
                "poiStyle.labelContent"
            ]
        },
        {
            "name": "周界围栏模块",
            "wdp_apis": [
                "new App.Range({...})",
                "rangeStyle.fillColor",
                "rangeStyle.outlineColor",
                "rangeStyle.height"
            ]
        },
        {
            "name": "视频窗口模块",
            "wdp_apis": [
                "new App.Window({...})",
                "windowStyle.url",
                "windowStyle.size",
                "windowStyle.offset"
            ]
        },
        {
            "name": "事件交互模块",
            "wdp_apis": [
                "App.Renderer.RegisterSceneEvent",
                "App.Renderer.RegisterSceneEvents",
                "OnWdpSceneIsReady",
                "OnEntityClicked",
                "OnMouseEnterEntity"
            ]
        },
        {
            "name": "相机控制模块",
            "wdp_apis": [
                "App.CameraControl.SetCameraPose",
                "App.CameraControl.FlyTo"
            ]
        }
    ],
    "api_flow": [
        {
            "step": 1,
            "description": "逐个创建AI摄像头POI标注",
            "api": "new App.Poi({...}) + App.Scene.Add(entity)",
            "params": {
                "entity": "new App.Poi({...})",
                "config": {
                    "location": "[121.464, 31.224, 47]",
                    "poiStyle": {
                        "markerNormalUrl": "camera_icon.png",
                        "labelContent": ["AI摄像头1", "#FFFFFFFF", 14]
                    },
                    "customId": "camera_poi_1"
                }
            }
        },
        {
            "step": 2,
            "description": "创建周界围栏区域",
            "api": "new App.Range({...}) + App.Scene.Add(entity)",
            "params": {
                "entity": "new App.Range({...})",
                "config": {
                    "polygon": {
                        "coordinates": "[[121.464, 31.224], [121.465, 31.224], ...]"
                    },
                    "rangeStyle": {
                        "fillColor": "rgba(255, 0, 0, 0.3)",
                        "outlineColor": "#ff0000",
                        "height": 50
                    },
                    "customId": "perimeter_zone_1"
                }
            }
        },
        {
            "step": 3,
            "description": "注册POI点击事件",
            "api": "App.Renderer.RegisterSceneEvent('OnEntityClicked', func)",
            "params": {
                "name": "OnEntityClicked",
                "func": "async (ev) => { if(ev.result.customId.startsWith('camera_poi')) { /* 聚焦相机并显示视频窗口 */ } }"
            }
        },
        {
            "step": 4,
            "description": "聚焦到选中的摄像头",
            "api": "App.CameraControl.SetCameraPose",
            "params": {
                "target": "${clickedPoiLocation}",
                "pitch": -69,
                "yaw": 176,
                "distance": 200
            }
        },
        {
            "step": 5,
            "description": "创建视频流窗口",
            "api": "new App.Window({...}) + App.Scene.Add(entity)",
            "params": {
                "entity": "new App.Window({...})",
                "config": {
                    "location": "${cameraLocation}",
                    "windowStyle": {
                        "url": "video_stream.html?cameraId=${cameraId}",
                        "size": [250, 190],
                        "offset": [0, 1.7]
                    },
                    "customId": "video_window_${cameraId}"
                }
            }
        }
    ],
    "data_flow": [
        {
            "step": "new App.Poi({...}) + App.Scene.Add(entity)",
            "output": "result.object（含 eid, customId, location）",
            "usage": "缓存用于清理；事件回调通过 customId 匹配业务数据"
        },
        {
            "step": "RegisterSceneEvent('OnEntityClicked') 回调",
            "output": "result.object.customId, result.object.location",
            "usage": "customId 用于 SetCameraPose 和 Window 定位；location 用于 Window 位置"
        }
    ],
    "cleanup_chain": [
        {
            "create": "new App.Poi({...}) + App.Scene.Add(entity)",
            "cleanup": "poiObj.Delete()"
        },
        {
            "create": "new App.Range({...}) + App.Scene.Add(entity)",
            "cleanup": "rangeObj.Delete()"
        },
        {
            "create": "new App.Window({...}) + App.Scene.Add(entity)",
            "cleanup": "windowObj.Delete()"
        },
        {
            "create": "RegisterSceneEvent",
            "cleanup": "App.Renderer.UnRegisterSceneEvent"
        }
    ],
    "pattern": {
        "type": "event-driven",
        "architecture": "entity-based-3d-interaction",
        "data_flow": "user-interaction-driven",
        "recommended_patterns": [
            "wdp-poi-window-interaction",
            "wdp-perimeter-warning"
        ],
        "key_features": [
            "3D场景实体管理",
            "事件驱动交互",
            "相机聚焦控制",
            "视频窗口动态创建"
        ]
    }
}