{
  "metadata": {
    "scenario_id": "ai-robot-inspection",
    "version": "3.1.0"
  },
  "id": "ai-robot-inspection",
  "name": "AI 机器人巡检场景",
  "keywords": [
    "机器人巡检",
    "自动巡航",
    "设备监测",
    "异常识别",
    "路径规划",
    "数据采集"
  ],
  "synonyms": [
    "智能巡检",
    "自动化巡检",
    "巡检机器人",
    "移动巡检",
    "轨迹规划",
    "设备巡检"
  ],
  "priority": 10,
  "goal": "让巡检对象沿路径移动，并在关键点联动窗口、状态和相机。",
  "task_breakdown": [
    "创建路径对象或确认已有路径",
    "创建或定位巡检实体",
    "将实体与路径运动能力绑定",
    "根据需要添加相机跟随或聚焦",
    "补充运动结束、停止和清理链路"
  ],
  "primary_skills": [
    "reference/scene/covering/bound/SKILL.md"
  ],
  "secondary_skills": [
    "reference/scene/covering/poi/SKILL.md",
    "reference/camera/camera-control/SKILL.md",
    "reference/renderer/SKILL.md"
  ],
  "required_clarifications": [
    "路径是新建还是已有",
    "巡检实体的对象类别和对象 Id 来源",
    "是否需要跟车或跟拍",
    "运动结束后是否循环、暂停或清理"
  ],
  "modules": [
    {
      "name": "路径实体模块",
      "wdp_apis": [
        "new App.Path({...})",
        "pathStyle.type",
        "pathStyle.lineColor",
        "pathStyle.lineWidth"
      ]
    },
    {
      "name": "粒子实体模块",
      "wdp_apis": [
        "new App.Particle({...})",
        "particleType",
        "particleStyle.scale3d",
        "particleStyle.rotation"
      ]
    },
    {
      "name": "路径绑定模块",
      "wdp_apis": [
        "new App.Bound({...})",
        "boundStyle.time",
        "boundStyle.bLoop",
        "boundStyle.speed"
      ]
    },
    {
      "name": "检查点标注模块",
      "wdp_apis": [
        "new App.Poi({...})",
        "poiStyle.markerNormalUrl",
        "poiStyle.labelContent"
      ]
    },
    {
      "name": "数据窗口模块",
      "wdp_apis": [
        "new App.Window({...})",
        "windowStyle.url",
        "windowStyle.size"
      ]
    },
    {
      "name": "场景管理模块",
      "wdp_apis": [
        "App.Scene.Add",
        "App.Scene.Update",
        "App.Scene.Delete"
      ]
    }
  ],
  "api_flow": [
    {
      "step": 1,
      "description": "创建巡检路径",
      "api": "new App.Path({...}) + App.Scene.Add(entity)",
      "params": {
        "entity": "new App.Path({...})",
        "config": {
          "polyline": {
            "coordinates": "[[121.453, 31.112, 69], [121.477, 31.092, 85], ...]"
          },
          "pathStyle": {
            "type": "arrow",
            "lineColor": "#00ff00",
            "lineWidth": 3
          },
          "customId": "inspection_path_1"
        }
      }
    },
    {
      "step": 2,
      "description": "创建检查点POI标注",
      "api": "new App.Poi({...}) + App.Scene.Add(entity)",
      "params": {
        "entity": "new App.Poi({...})",
        "config": {
          "location": "[121.453, 31.112, 69]",
          "poiStyle": {
            "markerNormalUrl": "checkpoint_icon.png",
            "labelContent": ["检查点A", "#FFFFFFFF", 14]
          },
          "customId": "checkpoint_A"
        }
      }
    },
    {
      "step": 3,
      "description": "创建机器人粒子实体",
      "api": "new App.Particle({...}) + App.Scene.Add(entity)",
      "params": {
        "entity": "new App.Particle({...})",
        "config": {
          "location": "[121.453, 31.112, 69]",
          "particleType": "vehicle_taxi",
          "particleStyle": {
            "scale3d": [1.5, 1.5, 1.5]
          },
          "customId": "robot_particle_1"
        }
      }
    },
    {
      "step": 4,
      "description": "绑定机器人到巡检路径",
      "api": "new App.Bound({...}) + App.Scene.Add(entity)",
      "params": {
        "entity": "new App.Bound({...})",
        "config": {
          "moving": "${robotParticle}",
          "path": "${inspectionPath}",
          "boundStyle": {
            "time": 120,
            "bLoop": false,
            "speed": 1.0
          },
          "customId": "robot_bound_1"
        }
      }
    },
    {
      "step": 5,
      "description": "注册路径移动结束事件监听",
      "api": "App.Renderer.RegisterSceneEvent('OnMoveAlongPathEndEvent', func)",
      "params": {
        "name": "OnMoveAlongPathEndEvent",
        "func": "async (ev) => { if(ev.result.customId === 'robot_bound_1') { /* 到达终点，触发数据采集 */ } }"
      }
    },
    {
      "step": 6,
      "description": "在检查点创建数据采集窗口",
      "api": "new App.Window({...}) + App.Scene.Add(entity)",
      "params": {
        "entity": "new App.Window({...})",
        "config": {
          "location": "${checkpointLocation}",
          "windowStyle": {
            "url": "inspection_data.html?pointId=${pointId}",
            "size": [300, 400]
          },
          "customId": "data_window_${pointId}"
        }
      }
    },
    {
      "step": 7,
      "description": "更新检查点POI状态",
      "api": "entity.Update({...})",
      "params": {
        "entity": "poiObj",
        "updateData": {
          "poiStyle": {
            "markerNormalUrl": "checkpoint_completed_icon.png",
            "labelContent": ["检查点A (已完成)", "#FFFFFFFF", 14]
          }
        }
      }
    }
  ],
  "data_flow": [
    {
      "step": "new App.Path({...}) + App.Scene.Add(entity)",
      "output": "result.object（pathObj）",
      "usage": "作为 Bound 构造函数的路径绑定对象"
    },
    {
      "step": "new App.Particle({...}) + App.Scene.Add(entity)",
      "output": "result.object（particleObj）",
      "usage": "作为 Bound 构造函数的移动实体绑定对象"
    },
    {
      "step": "OnMoveAlongPathEndEvent 回调",
      "output": "result.customId, result.passedPointIndex",
      "usage": "用于判断到达终点，触发数据采集和状态更新"
    }
  ],
  "cleanup_chain": [
    {"create": "new App.Path({...}) + App.Scene.Add(entity)", "cleanup": "pathObj.Delete()"},
    {"create": "new App.Poi({...}) + App.Scene.Add(entity)", "cleanup": "poiObj.Delete()"},
    {"create": "new App.Particle({...}) + App.Scene.Add(entity)", "cleanup": "particleObj.Delete()"},
    {"create": "new App.Bound({...}) + App.Scene.Add(entity)", "cleanup": "boundObj.Delete()"},
    {"create": "new App.Window({...}) + App.Scene.Add(entity)", "cleanup": "windowObj.Delete()"},
    {"create": "RegisterSceneEvent", "cleanup": "UnRegisterSceneEvent"}
  ],
  "pattern": {
    "type": "workflow-orchestration",
    "architecture": "entity-path-binding",
    "data_flow": "event-driven-animation",
    "recommended_patterns": ["wdp-path-roam-animation"],
    "key_features": [
      "路径动画控制",
      "实体绑定移动",
      "事件驱动数据采集",
      "动态状态更新",
      "可视化巡检过程"
    ]
  }
}