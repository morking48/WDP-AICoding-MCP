{
  "metadata": {
    "scenario_id": "ai-robot-inspection",
    "version": "3.0.0"
  },
  "id": "ai-robot-inspection",
  "name": "AI 机器人巡检场景",
  "keywords": [
    "机器人巡检",
    "自动巡航",
    "设备监测",
    "异常识别",
    "路径规划",
    "数据采集"
  ],
  "synonyms": [
    "智能巡检",
    "自动化巡检",
    "巡检机器人",
    "移动巡检",
    "轨迹规划",
    "设备巡检"
  ],
  "priority": 10,
  "goal": "让巡检对象沿路径移动，并在关键点联动窗口、状态和相机。",
  "task_breakdown": [
    "创建路径对象或确认已有路径",
    "创建或定位巡检实体",
    "将实体与路径运动能力绑定",
    "根据需要添加相机跟随或聚焦",
    "补充运动结束、停止和清理链路"
  ],
  "primary_skills": [
    "reference/scene/covering/bound/SKILL.md"
  ],
  "secondary_skills": [
    "reference/scene/covering/poi/SKILL.md",
    "reference/camera/camera-control/SKILL.md",
    "reference/renderer/SKILL.md"
  ],
  "pre_discovery": {
    "required": true,
    "strategy": "type_query_or_picker",
    "when": "object_id_missing",
    "target_skill": "wdp-api-scene-discovery",
    "discovery_path": "A_or_B",
    "steps": [
      "若用户无法提供巡检实体 ID / 路径对象 → 自动路由到 wdp-api-scene-discovery",
      "优先路径 A（屏幕拾取）：生成页面让用户点击巡检实体 → 拿到 entityId",
      "备选路径 B（实体扫描）：GetByType 或 GetAll 列出可移动实体供选择",
      "路径坐标若缺失 → 路径 E（PickerPoint 取点）",
      "发现后写入 Cold.entities.snapshot + Hot.selection 再继续主流程"
    ]
  },
  "required_clarifications": [
    "路径是新建还是已有",
    "巡检实体的对象类别和对象 Id 来源",
    "是否需要跟车或跟拍",
    "运动结束后是否循环、暂停或清理"
  ],
  "modules": [
    {
      "name": "路径实体模块",
      "wdp_apis": [
        "new App.Path()",
        "pathStyle.type",
        "pathStyle.lineColor",
        "pathStyle.lineWidth"
      ]
    },
    {
      "name": "粒子实体模块",
      "wdp_apis": [
        "new App.Particle()",
        "particleType",
        "particleStyle.scale",
        "particleStyle.rotation"
      ]
    },
    {
      "name": "路径绑定模块",
      "wdp_apis": [
        "new App.Bound()",
        "boundStyle.time",
        "boundStyle.bLoop",
        "boundStyle.speed"
      ]
    },
    {
      "name": "检查点标注模块",
      "wdp_apis": [
        "new App.Poi()",
        "poiStyle.markerNormalUrl",
        "poiStyle.text",
        "poiStyle.textStyle"
      ]
    },
    {
      "name": "数据窗口模块",
      "wdp_apis": [
        "new App.Window()",
        "windowStyle.url",
        "windowStyle.size",
        "windowStyle.followEntity"
      ]
    },
    {
      "name": "场景管理模块",
      "wdp_apis": [
        "App.Scene.Add",
        "App.Scene.Update",
        "App.Scene.Delete",
        "App.Scene.Creates"
      ]
    }
  ],
  "api_flow": [
    {
      "step": 1,
      "description": "批量创建巡检路径和检查点",
      "api": "App.Scene.Creates",
      "params": {
        "entities": [
          {
            "type": "Path",
            "polyline": {
              "coordinates": "[[121.453, 31.112, 69], [121.477, 31.092, 85], ...]"
            },
            "pathStyle": {
              "type": "arrow",
              "lineColor": "#00ff00",
              "lineWidth": 3
            },
            "customId": "inspection_path_1"
          },
          {
            "type": "Poi",
            "location": "[121.453, 31.112, 69]",
            "poiStyle": {
              "markerNormalUrl": "checkpoint_icon.png",
              "text": "检查点A"
            },
            "customId": "checkpoint_A"
          }
        ]
      }
    },
    {
      "step": 2,
      "description": "创建机器人粒子实体",
      "api": "App.Scene.Add",
      "params": {
        "entity": "new App.Particle()",
        "config": {
          "location": "[121.453, 31.112, 69]",
          "particleType": "vehicle_taxi",
          "particleStyle": {
            "scale": 1.5
          },
          "customId": "robot_particle_1"
        }
      }
    },
    {
      "step": 3,
      "description": "绑定机器人到巡检路径",
      "api": "App.Scene.Add",
      "params": {
        "entity": "new App.Bound()",
        "config": {
          "moving": "${robotParticle}",
          "path": "${inspectionPath}",
          "boundStyle": {
            "time": 120,
            "bLoop": false,
            "speed": 1.0
          },
          "customId": "robot_bound_1"
        }
      }
    },
    {
      "step": 4,
      "description": "注册路径移动事件监听",
      "api": "App.Renderer.RegisterSceneEvent",
      "params": {
        "events": [
          {
            "name": "OnBoundMoveEnd",
            "func": "async (ev) => { if(ev.result.customId === 'robot_bound_1') { /* 到达终点，触发数据采集 */ } }"
          }
        ]
      }
    },
    {
      "step": 5,
      "description": "在检查点创建数据采集窗口",
      "api": "App.Scene.Add",
      "params": {
        "entity": "new App.Window()",
        "config": {
          "location": "${checkpointLocation}",
          "windowStyle": {
            "url": "inspection_data.html?pointId=${pointId}",
            "size": "[300, 400]",
            "followEntity": true
          },
          "customId": "data_window_${pointId}"
        }
      }
    },
    {
      "step": 6,
      "description": "更新检查点POI状态",
      "api": "App.Scene.Update",
      "params": {
        "customId": "checkpoint_A",
        "updateData": {
          "poiStyle": {
            "markerNormalUrl": "checkpoint_completed_icon.png",
            "text": "检查点A (已完成)"
          }
        }
      }
    }
  ],
  "data_flow": [
    {
      "step": "App.Scene.Add(Path)",
      "output": "result.object（pathObj）",
      "usage": "作为 Bound 构造函数的路径绑定对象"
    },
    {
      "step": "App.Scene.Add(Particle)",
      "output": "result.object（particleObj）",
      "usage": "作为 Bound 构造函数的移动实体绑定对象"
    },
    {
      "step": "OnBoundMoveEnd 回调",
      "output": "result.customId, result.passedPointIndex",
      "usage": "用于判断到达终点，触发数据采集和状态更新"
    }
  ],
  "cleanup_chain": [
    {"create": "App.Scene.Creates(Path)", "cleanup": "pathObj.Delete()"},
    {"create": "App.Scene.Add(Particle)", "cleanup": "particleObj.Delete()"},
    {"create": "App.Scene.Add(Bound)", "cleanup": "boundObj.Delete()"},
    {"create": "App.Scene.Add(Window)", "cleanup": "windowObj.Delete()"},
    {"create": "RegisterSceneEvent", "cleanup": "UnregisterSceneEvent"}
  ],
  "pattern": {
    "type": "workflow-orchestration",
    "architecture": "entity-path-binding",
    "data_flow": "event-driven-animation",
    "recommended_patterns": ["wdp-path-roam-animation"],
    "key_features": [
      "路径动画控制",
      "实体绑定移动",
      "事件驱动数据采集",
      "动态状态更新",
      "可视化巡检过程"
    ]
  }
}
